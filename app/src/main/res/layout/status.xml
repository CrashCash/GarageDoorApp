<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android = "http://schemas.android.com/apk/res/android"
              android:layout_gravity = "center"
              android:orientation = "horizontal"
              android:layout_width = "wrap_content"
              android:layout_height = "wrap_content">
    <LinearLayout
        android:layout_gravity = "center"
        android:orientation = "vertical"
        android:layout_width = "wrap_content"
        android:layout_height = "wrap_content">
        <TextView
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:layout_gravity = "center"
            android:text = "Roll Up Door" />
        <ImageButton
            android:id = "@+id/status_roll"
            android:src = "@drawable/barberpole_red"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content" />
        <TextView
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:layout_gravity = "center"
            android:text = "Back Door" />
        <ImageButton
            android:id = "@+id/status_door"
            android:src = "@drawable/barberpole_red"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity = "center"
        android:orientation = "vertical"
        android:layout_width = "wrap_content"
        android:layout_height = "wrap_content">
        <TextView
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:layout_gravity = "center"
            android:text = "Armed" />
        <ImageButton
            android:id = "@+id/status_armed"
            android:src = "@drawable/barberpole_red"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content" />
        <TextView
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:layout_gravity = "center"
            android:text = "Beam" />
        <ImageButton
            android:id = "@+id/status_beam"
            android:src = "@drawable/barberpole_red"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content" />
    </LinearLayout>
</LinearLayout>